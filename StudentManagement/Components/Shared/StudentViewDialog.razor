@using StudentManagement.Features.Data.Models
@using StudentManagement.Features.Helpers

<MudDialog>
    <DialogContent>
        @if (Student != null)
        {
            <div class="d-flex flex-column align-center mb-4 mt-2">
                <MudAvatar Style="width:100px; height:100px;" Class="elevation-3 mb-2">
                    @if (!string.IsNullOrEmpty(Student.ProfileImage))
                    {
                        <MudImage Src="@Student.ProfileImage" Style="width:100%; height:100%; object-fit:cover;" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size: 4rem;" />
                    }
                </MudAvatar>
                <MudText Typo="Typo.h5">@Student.FirstName @Student.LastName</MudText>
                <MudText Typo="Typo.subtitle2" Class="text-secondary">Year @Student.YearLevel - Section @Student.Section</MudText>
            </div>
            <MudDivider Class="mb-4" />
            <MudList T="string" ReadOnly="true">
                <MudListItem Icon="@Icons.Material.Filled.Badge">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.caption">Student Number</MudText>
                        <MudText Typo="Typo.body1">@Student.StudentNumber</MudText>
                    </div>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Person">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.caption">Name</MudText>
                        <MudText Typo="Typo.body1">@Student.FirstName @Student.MiddleName @Student.LastName</MudText>
                    </div>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Cake">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.caption">Date of Birth</MudText>
                        <MudText Typo="Typo.body1">@DateHelper.FormatDate(Student.DateOfBirth)</MudText>
                    </div>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Wc">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.caption">Gender</MudText>
                        <MudText Typo="Typo.body1">@Student.Gender</MudText>
                    </div>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.School">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.caption">Year & Section</MudText>
                        <MudText Typo="Typo.body1">Year @Student.YearLevel - @Student.Section</MudText>
                    </div>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Info">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.caption">Status</MudText>
                        <MudText Typo="Typo.body1">@Student.Status.ToString()</MudText>
                    </div>
                </MudListItem>
            </MudList>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Student? Student { get; set; }

    private void Close() => MudDialog.Close(DialogResult.Ok(true));
}
